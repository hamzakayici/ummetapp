{
  "expo": {
    "name": "Ummet",
    "slug": "ummet",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "ummet",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1A14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ummet.app",
      "buildNumber": "2",
      "splash": {
        "tabletImage": "./assets/splash-icon-ipad.png"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Namaz vakitlerini ve Kıble yönünü belirlemek için konumunuza ihtiyacımız var.",
        "NSMotionUsageDescription": "Kıble pusulası için sensör erişimi gereklidir.",
        "UIBackgroundModes": [
          "audio"
        ]
      },
      "appleTeamId": "WZ3W8Y7U6Z"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B5E3A"
      },
      "package": "com.ummet.app",
      "versionCode": 2,
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-sensors",
      "expo-location",
      "expo-av",
      "./plugins/withWidget",
      "expo-notifications",
      "./plugins/withEzanSounds",
      "expo-updates"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6760871547"
      }
    }
  }
}
