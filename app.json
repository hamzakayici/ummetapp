{
  "expo": {
    "name": "Ümmet",
    "slug": "ummet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "ummet",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#0A1A14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ummet.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Namaz vakitlerini ve Kıble yönünü belirlemek için konumunuza ihtiyacımız var.",
        "NSMotionUsageDescription": "Kıble pusulası için sensör erişimi gereklidir.",
        "UIBackgroundModes": ["audio"]
      },
      "appleTeamId": "WZ3W8Y7U6Z"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0F14"
      },
      "package": "com.ummet.app",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-sensors",
      "expo-location",
      "expo-av",
      "./plugins/withWidget",
      "expo-notifications",
      "./plugins/withEzanSounds"
    ]
  }
}
